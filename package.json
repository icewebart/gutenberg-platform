{
  "name": "gutenberg-platform",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:all": "pnpm run --parallel --filter './apps/*' dev",
    "build": "pnpm --filter shared build && pnpm --filter web build && pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build"
  }
}
